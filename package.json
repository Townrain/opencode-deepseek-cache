{
  "name": "opencode-deepseek-cache",
  "version": "1.2.0",
  "description": "DeepSeek context caching optimization plugin for OpenCode",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome check --write .",
    "lint:ci": "biome ci .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@opencode-ai/plugin": "^1.0.0",
    "@types/node": "^25.9.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT"
}
